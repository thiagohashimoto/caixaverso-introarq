# Arquivo de Exemplo para Variáveis de Ambiente - Nginx
# Copie este arquivo para .env e ajuste conforme necessário

# ============================================================
# NGINX CONFIGURATION - DEVELOPMENT
# ============================================================

# Domínio/Hostname
NGINX_SERVER_NAME=localhost
NGINX_LISTEN_PORT_HTTP=80
NGINX_LISTEN_PORT_HTTPS=443

# Certificados SSL (caminhos dentro do container)
NGINX_CERT_PATH=/etc/nginx/certs/server.crt
NGINX_KEY_PATH=/etc/nginx/certs/server.key

# ============================================================
# NGINX RATE LIMITING - DEVELOPMENT
# ============================================================

# Taxa de requisições por segundo (geral)
# Padrão: 10 req/s
NGINX_RATE_LIMIT_GENERAL=10

# Taxa de requisições por segundo (API)
# Padrão: 5 req/s
NGINX_RATE_LIMIT_API=5

# Taxa de requisições por segundo (operações de escrita)
# Padrão: 2 req/s
NGINX_RATE_LIMIT_WRITE=2

# Taxa de requisições por segundo (autenticação/login)
# Padrão: 3 req/s (brute force protection)
NGINX_RATE_LIMIT_AUTH=3

# Burst size (quantas requisições podem ser enfileiradas)
# Padrão: 20 (geral), 5 (write)
NGINX_BURST_GENERAL=20
NGINX_BURST_WRITE=5

# ============================================================
# NGINX CACHING - DEVELOPMENT
# ============================================================

# TTL para GET requests (/api/*)
# Formato: 5m (5 minutos), 1h (1 hora), 1d (1 dia)
NGINX_CACHE_TTL_API=5m

# TTL para arquivos estáticos (js, css, imagens)
NGINX_CACHE_TTL_STATIC=30d

# Tamanho máximo da zona de cache (API)
NGINX_CACHE_SIZE_API=100m

# Tamanho máximo da zona de cache (Static)
NGINX_CACHE_SIZE_STATIC=500m

# Tamanho máximo total que pode ser armazenado em cache
NGINX_CACHE_MAX_SIZE_API=1g
NGINX_CACHE_MAX_SIZE_STATIC=500m

# ============================================================
# NGINX COMPRESSÃO - DEVELOPMENT
# ============================================================

# Habilitar gzip
NGINX_GZIP_ENABLED=on

# Nível de compressão (1-9, 6 é padrão bom)
# 1 = rápido, menos compressão
# 9 = lento, mais compressão
NGINX_GZIP_LEVEL=6

# Tamanho mínimo para comprimir
NGINX_GZIP_MIN_LENGTH=1000

# Tipos MIME para comprimir
# Padrão: text/plain, text/css, application/json, etc
NGINX_GZIP_TYPES=text/plain text/css text/xml text/javascript application/json application/javascript application/xml+rss application/atom+xml image/svg+xml

# ============================================================
# NGINX UPSTREAM (BACKEND) - DEVELOPMENT
# ============================================================

# Host do backend
MINIERP_HOST=minierp
MINIERP_PORT=8080

# Número máximo de falhas antes de marcar como down
MINIERP_MAX_FAILS=3

# Tempo antes de tentar novamente após falha
MINIERP_FAIL_TIMEOUT=30s

# Número de conexões keepalive para backend
MINIERP_KEEPALIVE=32

# ============================================================
# NGINX TIMEOUT - DEVELOPMENT
# ============================================================

# Timeout para conectar ao backend
NGINX_PROXY_CONNECT_TIMEOUT=30s

# Timeout para ler resposta do backend
NGINX_PROXY_READ_TIMEOUT=30s

# Timeout para enviar requisição ao backend
NGINX_PROXY_SEND_TIMEOUT=30s

# Timeout keepalive com cliente
NGINX_KEEPALIVE_TIMEOUT=65s

# Máximo requisições por keepalive
NGINX_KEEPALIVE_REQUESTS=100

# ============================================================
# NGINX WORKERS - DEVELOPMENT
# ============================================================

# Número de worker processes
# auto = número de CPUs disponíveis
NGINX_WORKER_PROCESSES=auto

# Número máximo de conexões por worker
NGINX_WORKER_CONNECTIONS=4096

# Máximo de arquivos abertos por worker
NGINX_WORKER_RLIMIT_NOFILE=65535

# ============================================================
# NGINX BUFFERS - DEVELOPMENT
# ============================================================

# Tamanho do buffer de proxy
NGINX_PROXY_BUFFER_SIZE=4k

# Número de buffers
NGINX_PROXY_BUFFERS=8 4k

# Tamanho busy buffer
NGINX_PROXY_BUSY_BUFFERS_SIZE=8k

# ============================================================
# NGINX CORS - DEVELOPMENT
# ============================================================

# Origins permitidas para CORS
# Em desenvolvimento: permite localhost
# Em produção: defina domínios específicos
NGINX_CORS_ALLOW_ORIGINS=localhost,127.0.0.1,http://localhost:3000,http://localhost:5173

# Métodos permitidos
NGINX_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# Headers permitidos
NGINX_CORS_ALLOW_HEADERS=DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Authorization

# Headers expostos
NGINX_CORS_EXPOSE_HEADERS=Content-Length,Content-Range

# Max age para CORS preflight (em segundos)
# 1728000 = 20 dias
NGINX_CORS_MAX_AGE=1728000

# Permitir credenciais
NGINX_CORS_ALLOW_CREDENTIALS=true

# ============================================================
# NGINX IP WHITELISTING - DEVELOPMENT
# ============================================================

# IPs permitidos para /admin
# Formato: IP ou CIDR (ex: 192.168.1.0/24)
NGINX_ADMIN_WHITELIST=127.0.0.1,172.16.0.0/12,10.0.0.0/8

# IPs permitidos para /metrics
NGINX_METRICS_WHITELIST=127.0.0.1,172.16.0.0/12,10.0.0.0/8

# ============================================================
# NGINX LOGGING - DEVELOPMENT
# ============================================================

# Nível de log de erro
# debug, info, notice, warn, error, crit, alert, emerg
NGINX_ERROR_LOG_LEVEL=warn

# Habilitar access log
NGINX_ACCESS_LOG_ENABLED=on

# Habilitar security log
NGINX_SECURITY_LOG_ENABLED=on

# ============================================================
# NGINX SEGURANÇA - DEVELOPMENT
# ============================================================

# Habilitar HSTS (Strict-Transport-Security)
NGINX_HSTS_ENABLED=on

# HSTS max-age (em segundos)
# 31536000 = 1 ano
NGINX_HSTS_MAX_AGE=31536000

# Incluir subdomínios em HSTS
NGINX_HSTS_INCLUDE_SUBDOMAINS=on

# HSTS preload (aceitar em navegadores)
NGINX_HSTS_PRELOAD=on

# X-Frame-Options
NGINX_X_FRAME_OPTIONS=SAMEORIGIN

# X-Content-Type-Options
NGINX_X_CONTENT_TYPE_OPTIONS=nosniff

# X-XSS-Protection
NGINX_X_XSS_PROTECTION=1; mode=block

# Referrer-Policy
NGINX_REFERRER_POLICY=strict-origin-when-cross-origin

# ============================================================
# BACKEND APPLICATION - DEVELOPMENT
# ============================================================

# Configurações do Spring Boot (via docker-compose)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/caixaverso
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=admin123
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_PROFILES_ACTIVE=dev

# ============================================================
# DATABASE - DEVELOPMENT
# ============================================================

POSTGRES_DB=caixaverso
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_PORT=5432

# ============================================================
# MESSAGE BROKER - DEVELOPMENT
# ============================================================

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# ============================================================
# NOTAS IMPORTANTES
# ============================================================

# 1. DEVELOPMENT vs PRODUCTION
#    - Development: certificado auto-assinado
#    - Production: Use Let's Encrypt
#
# 2. RATE LIMITING
#    - Ajuste baseado no volume de tráfego esperado
#    - Monitorar logs para rate limiting excessivo
#
# 3. CACHE
#    - Development: TTL menor (5 minutos)
#    - Production: TTL maior (1 hora+)
#
# 4. CORS
#    - Development: permite localhost
#    - Production: defina apenas domínios necessários
#
# 5. LOGGING
#    - Development: log detalhado
#    - Production: log otimizado, considere centralizar
#
# 6. SECURITY
#    - Development: relaxado para facilitar testes
#    - Production: rigoroso (HSTS, CSP, etc)

# ============================================================
# EXEMPLO DE USO
# ============================================================

# 1. Copie este arquivo
#    cp .env.example .env

# 2. Edite conforme suas necessidades
#    nano .env

# 3. Use em docker-compose (não precisa, já está no arquivo)
#    docker-compose up -d

# 4. Ou use em um script Bash
#    source .env
#    echo $NGINX_RATE_LIMIT_API

# 5. Ou use em uma aplicação Python
#    from dotenv import load_dotenv
#    import os
#    load_dotenv()
#    rate_limit = os.getenv('NGINX_RATE_LIMIT_API')
